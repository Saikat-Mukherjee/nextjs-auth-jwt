# ── Database ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# ── Auth ──────────────────────────────────────────────────────────────────
# Use a long, random string (e.g. openssl rand -hex 32)
TOKEN_SECRET=replace_with_a_long_random_secret

# ── Base path (leave empty if hosting at root /) ──────────────────────────
NEXT_BASE_PATH=/auth-jwt
NEXT_PUBLIC_BASE_PATH=/auth-jwt
